{
  "manifest_version": 3,
  "name": "配置管理插件",
  "description": "一个很神奇的插件，有手就行，双击开启神奇之旅。",
  "version": "1.1.0",
  "action": {
    "default_popup": "pages/popup.html"
  },
  "options_page": "pages/options.html",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "scripting",
    "clipboardWrite",
    "declarativeNetRequest",
    "cookies"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "icons": {
    "16": "images/16px.png",
    "32": "images/32px.png",
    "48": "images/48px.png",
    "128": "images/128px.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "js/content.js"
      ]
    }
  ]
}
